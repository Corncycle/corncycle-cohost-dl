tence of mode 7.","children":[],"postId":891823,"inReplyTo":null,"hasCohostPlus":false,"hidden":false},"canInteract":"allowed","canEdit":"not-allowed","canHide":"not-allowed","poster":{"projectId":28756,"handle":"AlexStemcell","displayName":"🏳️‍🌈 Alex Stemcell","dek":"indie game developer","description":"Existentially Gay - Level 43 Lewdologist","avatarURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F28756-c3d86492-d925-4672-9542-7a334b9c5d09-profile.png","avatarPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F28756-c3d86492-d925-4672-9542-7a334b9c5d09-profile.png","headerURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Fheader\u002F28756-d69c934e-c93f-4a7c-a241-2144b6f232ce-profile.jpg","headerPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Fheader\u002F28756-d69c934e-c93f-4a7c-a241-2144b6f232ce-profile.jpg","privacy":"public","url":"","pronouns":"EN: him, DE: er","flags":[],"avatarShape":"roundrect","loggedOutPostVisibility":"public","frequentlyUsedTags":[],"askSettings":{"enabled":true,"allowAnon":true,"requireLoggedInAnon":true},"contactCard":[],"deleteAfter":null,"isSelfProject":null}},{"comment":{"commentId":"fd1a138d-afcb-491b-9207-a83cb3dde165","postedAtISO":"2023-01-24T07:08:40.062Z","deleted":false,"body":"I soooo remember this being an old trick people did in MSPaint back in the day. Really cool stuff.","children":[],"postId":891823,"inReplyTo":null,"hasCohostPlus":false,"hidden":false},"canInteract":"allowed","canEdit":"not-allowed","canHide":"not-allowed","poster":{"projectId":13782,"handle":"wunk","displayName":"","dek":"wao!","description":"Software Engineer also Art sometimes","avatarURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F13782-e66c4642-3037-4b5a-a5ec-e10f8f143ef5-profile.png","avatarPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F13782-e66c4642-3037-4b5a-a5ec-e10f8f143ef5-profile.png","headerURL":null,"headerPreviewURL":null,"privacy":"public","url":"https:\u002F\u002Ftwitter.com\u002FWunkolo","pronouns":"he\u002Fhim","flags":[],"avatarShape":"circle","loggedOutPostVisibility":"public","frequentlyUsedTags":[],"askSettings":{"enabled":false,"allowAnon":false,"requireLoggedInAnon":true},"contactCard":[],"deleteAfter":null,"isSelfProject":null}},{"comment":{"commentId":"98973a1a-68ea-4452-80ff-d877e9f7ac7f","postedAtISO":"2023-01-26T15:07:50.063Z","deleted":false,"body":"```python\n#!\u002Fusr\u002Fbin\u002Fenv python3\nimport cv2\nimport numpy as np\nimport math\n\ndef sheer(img, ratio, y=False, origin=None):\n    result = img.copy()\n    if y:\n        result = np.transpose(result, (1, 0, 2))\n    if origin is None:\n        origin = result.shape[0] \u002F 2\n    for i in range(result.shape[0]):\n        shift = round((i - origin) * ratio)\n        if shift \u003E 0:\n            result[i,shift:] = result[i,:-shift]\n        elif shift \u003C 0:\n            result[i,:shift] = result[i,-shift:]\n    if y:\n        result = np.transpose(result, (1, 0, 2))\n    return result\n\ndef rotate(img, angle):\n    img = sheer(img, -math.tan(angle \u002F 2))\n    img = sheer(img, math.sin(angle), y=True)\n    img = sheer(img, -math.tan(angle \u002F 2))\n    return img\n\nif __name__ == '__main__':\n    a = cv2.imread('fox.png')\n    # Photo by Jeremy Hynes https:\u002F\u002Funsplash.com\u002Fphotos\u002FUeCG6uMSKdE\n    b = a.copy()\n    for i in range(120):\n        b = rotate(b, math.pi \u002F 6)\n    cv2.imshow('result', b)\n    cv2.waitKey()\n```\nLook at what I got with this code https:\u002F\u002Fi.imgur.com\u002FBhrRrJG.png\nThe code was slightly modified (+0.5 to origin, otherwise it looked bad)\nThis extremely naive implementation of mine survives 12000 rotations by 30 degrees!","children":[],"postId":891823,"inReplyTo":null,"hasCohostPlus":false,"hidden":false},"canInteract":"allowed","canEdit":"not-allowed","canHide":"not-allowed","poster":{"projectId":132133,"handle":"sanfierro","displayName":"","dek":"","description":""