:<!-- --><span style="color:#88c0d0">checked<!-- --></span><span style="color:#81a1c1">+#display<!-- --></span>::<!-- --><span style="color:#88c0d0">before <!-- --></span><span style="color:#e8ba36">{<!-- --><br/></span><span style="color:#e8ba36">        <!-- --></span><span style="color:#8fbcbb">content<!-- --></span>: <!-- --><span style="color:#a3be8c">&quot;checked&quot;<!-- --><br/></span><span style="color:#a3be8c">    <!-- --></span><span style="color:#e8ba36">}<!-- --><br/></span><span style="color:#e8ba36">    <!-- --></span><span style="color:#81a1c1">#myBoolean<!-- --></span>:<!-- --><span style="color:#88c0d0">not<!-- --></span><span style="color:#e8ba36">(<!-- --></span>:<!-- --><span style="color:#88c0d0">checked<!-- --></span><span style="color:#e8ba36">)<!-- --></span><span style="color:#81a1c1">+#display<!-- --></span>::<!-- --><span style="color:#88c0d0">before <!-- --></span><span style="color:#e8ba36">{<!-- --><br/></span><span style="color:#e8ba36">        <!-- --></span><span style="color:#8fbcbb">content<!-- --></span>: <!-- --><span style="color:#a3be8c">&quot;unchecked&quot;<!-- --><br/></span><span style="color:#a3be8c">    <!-- --></span><span style="color:#e8ba36">}<!-- --><br/></span><span style="color:#e8ba36">    <!-- --></span><span style="color:#eceff4">.<!-- --></span><span style="color:#81a1c1">hidden <!-- --></span><span style="color:#e8ba36">{<!-- --><br/></span><span style="color:#e8ba36">        <!-- --></span><span style="color:#8fbcbb">display<!-- --></span>: <!-- --><span style="color:#81a1c1">none<!-- --><br/></span><span style="color:#81a1c1">    <!-- --></span><span style="color:#e8ba36">}<!-- --><br/></span><span style="color:#e8ba36">&lt;/<!-- --></span><span style="color:#81a1c1">style<!-- --></span><span style="color:#e8ba36">&gt;<!-- --></span></pre>
