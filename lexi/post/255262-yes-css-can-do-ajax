n>:<!-- --><span style="color:#88c0d0">checked <!-- --></span><span style="color:#e8ba36">{<!-- --><br/></span><span style="color:#e8ba36">    <!-- --></span><span style="color:#8fbcbb">background<!-- --></span>: <!-- --><span style="color:#88c0d0">var<!-- --></span><span style="color:#e8ba36">(<!-- --></span><span style="color:#81a1c1">--request1<!-- --></span><span style="color:#e8ba36">)<!-- --><br/></span><span style="color:#e8ba36">}<!-- --><br/></span><span style="color:#81a1c1">button2<!-- --></span>:<!-- --><span style="color:#88c0d0">checked <!-- --></span><span style="color:#e8ba36">{<!-- --><br/></span><span style="color:#e8ba36">    <!-- --></span><span style="color:#8fbcbb">background<!-- --></span>: <!-- --><span style="color:#88c0d0">var<!-- --></span><span style="color:#e8ba36">(<!-- --></span><span style="color:#81a1c1">--request2<!-- --></span><span style="color:#e8ba36">)<!-- --><br/></span><span style="color:#e8ba36">}<!-- --></span></pre>
