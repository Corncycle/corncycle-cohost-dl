ailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["projects","isReaderMuting"],{"input":{"projectHandle":"staff"},"type":"query"}],"queryHash":"[[\"projects\",\"isReaderMuting\"],{\"input\":{\"projectHandle\":\"staff\"},\"type\":\"query\"}]"},{"state":{"data":false,"dataUpdateCount":1,"dataUpdatedAt":1727234618567,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["projects","isReaderBlocking"],{"input":{"projectHandle":"staff"},"type":"query"}],"queryHash":"[[\"projects\",\"isReaderBlocking\"],{\"input\":{\"projectHandle\":\"staff\"},\"type\":\"query\"}]"},{"state":{"data":{"readerToProject":2},"dataUpdateCount":1,"dataUpdatedAt":1727234618596,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["projects","followingState"],{"input":{"projectHandle":"staff"},"type":"query"}],"queryHash":"[[\"projects\",\"followingState\"],{\"input\":{\"projectHandle\":\"staff\"},\"type\":\"query\"}]"},{"state":{"data":{"post":{"postId":7611443,"headline":"cohost to shut down at end of 2024","publishedAt":"2024-09-09T19:48:56.277Z","filename":"7611443-cohost-to-shut-down","transparentShareOfPostId":null,"shareOfPostId":null,"state":1,"numComments":682,"cws":[],"tags":["cohost corner","financials"],"hasCohostPlus":true,"pinned":false,"commentsLocked":false,"sharesLocked":false,"blocks":[{"type":"markdown","markdown":{"content":"*also the August 2024 financial update, but I’m trying not to bury the lede.*"}},{"type":"markdown","markdown":{"content":"Hi everyone,"}},{"type":"markdown","markdown":{"content":"We have come to the decision to cease operations of cohost and anti software software club due to lack of funding and burnout. As of today, none of us are being paid for our labor[^1]; all of our money in the bank, and any money coming in from people who buy our merch or don’t cancel cohost plus, is going towards servers and operations — paying the bills so we can turn the lights off with as little disruption as possible."}},{"type":"markdown","markdown":{"content":"[^1]: on that note, we’re looking for new jobs. we’ll each be posting about that bit individually."}},{"type":"markdown","markdown":{"content":"cohost will become read-only on Tuesday, October 1st. At this time, we will make best-effort attempts to keep the servers online through the end of 2024."}},{"type":"markdown","markdown":{"content":"Development focus has immediately shifted to data export. We have offered minimal data export for GDPR compliance for a while now, but this is a barebones system that doesn’t meet our quality standards. We will be improving this system over the next few weeks and will issue full data exports for all users when the site goes read-only. We will continue to offer downloads of your data export through the end of the read-only period."}},{"type":"markdown","markdown":{"content":"When the read-only period concludes, we will delete all of your data from our servers without a backup.  Even now we want to reiterate that we think “data brokerage” and other common practices of the software industry are inimical to who we are as people, and we would never consider selling your data to others or asserting any rights to stuff you posted under any circumstance. "}},{"type":"markdown","markdown":{"content":"Majority control of the cohost source code will be transferred to the person who funded the majority of our operations, as per the terms of the funding documents we signed with them; Colin and I will retain small stakes so we have some input on what happens to it, at their request."}},{"type":"markdown","markdown":{"content":"---"}},{"type":"markdown","markdown":{"content":"So, what happened? If you’ve read our financial updates, you know that we have never been profitable. This isn’t surprising, even with a team of four; social media is a notoriously unprofitable industry. We had planned to bring in new revenue with eggbux (our tipping and subscription product) but policy changes from Stripe forced us to cancel earlier this year."}},{"type":"markdown","markdown":{"content":"Since then, we’ve struggled to fill the revenue and morale gap. Colin and I have been doing this for five years, Aidan for three, Kara for nearly two. We’ve been at or over capacity on moderation, engineering, and general operations nearly this entire time. We have all been on-call 24\u002F7\u002F365 since we launched two and a half years ago. The day-to-day needs of just running the site meant developing alternative funding options wasn’t possible. "}},{"type":"markdown","markdown":{"content":"MAU and MRR are down across the year. We’ve managed to build a social media platform that many of our users love, but we just don’t have enough users and we don’t have the resources to safely scale up. It’s important to know when to call it quits."}},{"type":"markdown","markdown":{"content":"We’re grateful for all the incredible things y’all have created on cohost. We’re grateful for eggbug. We’re grateful that we were able to try and show a better path for social media, even if it didn’t work out exactly as we would have liked."}},{"type":"markdown","markdown":{"content":"We’re going to do our best to keep things online through the end of the year with the money we have, but we might need additional funding to keep things up until then. If you would be able to contribute funds if necessary, please e-mail us at corp@antisoftware.club."}},{"type":"markdown","markdown":{"content":"Thank you all for having used cohost. We’ll see you around. :eggbug:"}},{"type":"markdown","markdown":{"content":"~ jae (and colin, and aidan, and kara)"}},{"type":"markdown","markdown":{"content":"---"}},{"type":"markdown","markdown":{"content":"## Timeline"}},{"type":"markdown","markdown":{"content":"- Immediately: self-service account deletions are available in the [settings page](https:\u002F\u002Fcohost.org\u002Frc\u002Fuser\u002Fsettings). account sign-up and activation is no longer available. Please note that **if you delete your account before receiving a data export, you will not receive one;** there won’t be any data left for us to export.\n- October 1, 2024: cohost will become read-only. all cohost plus subscriptions will be cancelled. account deletions will remain available.\n- starting October 1, 2024: we will begin processing data exports for all users. we expect this process to take some time. once your export is ready, you will receive an e-mail with a link to download it. data export downloads will remain available until the servers shut down on December 31.\n- December 31, 2024: cohost will go fully offline. all user data will be deleted on our way out the door.\n- January 1, 2025: we will set [cohost.org](http:\u002F\u002Fcohost.org) to redirect to the wayback machine[^2] to prevent link rot. this is something we will be paying for out of pocket since ASSC will no longer be an operating concern, but it’s max $100 per year total so it’s fine."}},{"type":"markdown","markdown":{"content":"[^2]: speaking of which, if you’re with archive team please reach out. we’d like to help make sure there’s a recent archive of all public posts but don’t know who to talk to."}},{"type":"markdown","markdown":{"content":"## FAQ"}},{"type":"markdown","markdown":{"content":"*this space intentionally left blank while we wait for people to frequently ask questions*"}},{"type":"markdown","markdown":{"content":"---"}},{"type":"markdown","markdown":{"content":"# August 2024 financial update"}},{"type":"markdown","markdown":{"content":"| Category | As of August 31 | As of July 31 | % Change |\n| --- | --- | --- | --- |\n| Expenses | $41,605 | $41,052 | \u003Cspan style=\"color:red;\"\u003E1.35%\u003C\u002Fspan\u003E |\n| Income | $16,307 | $28,405 | \u003Cspan style=\"color:red;\"\u003E-42.59%\u003C\u002Fspan\u003E |\n| Net income | -$25,297 | -$12,647 | \u003Cspan style=\"color:red;\"\u003E-100.03%\u003C\u002Fspan\u003E |\n| Active subscribers | 3,046 | 3,128 | \u003Cspan style=\"color:red;\"\u003E-2.62%\u003C\u002Fspan\u003E |\n| MRR | $19,477 | $20,015 | \u003Cspan style=\"color:red;\"\u003E-2.69%\u003C\u002Fspan\u003E |\n| Subscriber churn rate | 3.18% | 3.07% | \u003Cspan style=\"color:red;\"\u003E3.58%\u003C\u002Fspan\u003E |\n| Revenue per subscriber | $6.39 | $6.40 | \u003Cspan style=\"color:red;\"\u003E-0.16%\u003C\u002Fspan\u003E |\n| MAU | 16,846 | 18,612 | \u003Cspan style=\"color:red;\"\u003E-9.49%\u003C\u002Fspan\u003E |\n| MAU → Subscriber conversion rate | 18% | 16.8% | \u003Cspan style=\"color:green;\"\u003E7.14%\u003C\u002Fspan\u003E |\n| Artist Alley listing weeks sold | 73 | 89 | \u003Cspan style=\"color:red;\"\u003E-17.98%\u003C\u002Fspan\u003E |"}},{"type":"markdown","markdown":{"content":"Not great!"}}],"plainTextBody":"*also the August 2024 financial update, but I’m trying not to bury the lede.*\n\nHi everyone,\n\nWe have come to the decision to cease operations of cohost and anti software software club due to lack of funding and burnout. As of today, none of us are being paid for our labor[^1]; all of our money in the bank, and any money coming in from people who buy our merch or don’t cancel cohost plus, is going towards servers and operations — paying the bills so we can turn the lights off with as little disruption as possible.\n\n[^1]: on that note, we’re looking for new jobs. we’ll each be posting about that bit individually.\n\ncohost will become read-only on Tuesday, October 1st. At this time, we will make best-effort attempts to keep the servers online through the end of 2024.\n\nDevelopment focus has immediately shifted to data export. We have offered minimal data export for GDPR compliance for a while now, but this is a barebones system that doesn’t meet our quality standards. We will be improving this system over the next few weeks and will issue full data exports for all users when the site goes read-only. We will continue to offer downloads of your data export through the end of the read-only period.\n\nWhen the read-only period concludes, we will delete all of your data from our servers without a backup.  Even now we want to reiterate that we think “data brokerage” and other common practices of the software industry are inimical to who we are as people, and we would never consider selling your data to others or asserting any rights to stuff you posted under any circumstance. \n\nMajority control of the cohost source code will be transferred to the person who funded the majority of our operations, as per the terms of the funding documents we signed with them; Colin and I will retain small stakes so we have some input on what happens to it, at their request.\n\n---\n\nSo, what happened? If you’ve read our financial updates, you know that we have never been profitable. This isn’t surprising, even with a team of four; social media is a notoriously unprofitable industry. We had planned to bring in new revenue with eggbux (our tipping and subscription product) but policy changes from Stripe forced us to cancel earlier this year.\n\nSince then, we’ve struggled to fill the revenue and morale gap. Colin and I have been doing this for five years, Aidan for three, Kara for nearly two. We’ve been at or over capacity on moderation, engineering, and general operations nearly this entire time. We have all been on-call 24\u002F7\u002F365 since we launched two and a half years ago. The day-to-day needs of just running the site meant developing alternative funding options wasn’t possible. \n\nMAU and MRR are down across the year. We’ve managed to build a social media platform that many of our users love, but we just don’t have enough users and we don’t have the resources to safely scale up. It’s important to know when to call it quits.\n\nWe’re grateful for all the incredible things y’all have created on cohost. We’re grateful for eggbug. We’re grateful that we were able to try and show a better path for social media, even if it didn’t work out exactly as we would have liked.\n\nWe’re going to do our best to keep things online through the end of the year with the money we have, but we might need additional funding to keep things up until then. If you would be able to contribute funds if necessary, please e-mail us at corp@antisoftware.club.\n\nThank you all for having used cohost. We’ll see you around. :eggbug:\n\n~ jae (and colin, and aidan, and kara)\n\n---\n\n## Timeline\n\n- Immediately: self-service account deletions are available in the [settings page](https:\u002F\u002Fcohost.org\u002Frc\u002Fuser\u002Fsettings). account sign-up and activation is no longer available. Please note that **if you delete your account before receiving a data export, you will not receive one;** there won’t be any data left for us to export.\n- October 1, 2024: cohost will become read-only. all cohost plus subscriptions will be cancelled. account deletions will remain available.\n- starting October 1, 2024: we will begin processing data exports for all users. we expect this process to take some time. once your export is ready, you will receive an e-mail with a link to download it. data export downloads will remain available until the servers shut down on December 31.\n- December 31, 2024: cohost will go fully offline. all user data will be deleted on our way out the door.\n- January 1, 2025: we will set [cohost.org](http:\u002F\u002Fcohost.org) to redirect to the wayback machine[^2] to prevent link rot. this is something we will be paying for out of pocket since ASSC will no longer be an operating concern, but it’s max $100 per year total so it’s fine.\n\n[^2]: speaking of which, if you’re with archive team please reach out. we’d like to help make sure there’s a recent archive of all public posts but don’t know who to talk to.\n\n## FAQ\n\n*this space intentionally left blank while we wait for people to frequently ask questions*\n\n---\n\n# August 2024 financial update\n\n| Category | As of August 31 | As of July 31 | % Change |\n| --- | --- | --- | --- |\n| Expenses | $41,605 | $41,052 | \u003Cspan style=\"color:red;\"\u003E1.35%\u003C\u002Fspan\u003E |\n| Income | $16,307 | $28,405 | \u003Cspan style=\"color:red;\"\u003E-42.59%\u003C\u002Fspan\u003E |\n| Net income | -$25,297 | -$12,647 | \u003Cspan style=\"color:red;\"\u003E-100.03%\u003C\u002Fspan\u003E |\n| Active subscribers | 3,046 | 3,128 | \u003Cspan style=\"color:red;\"\u003E-2.62%\u003C\u002Fspan\u003E |\n| MRR | $19,477 | $20,015 | \u003Cspan style=\"color:red;\"\u003E-2.69%\u003C\u002Fspan\u003E |\n| Subscriber churn rate | 3.18% | 3.07% | \u003Cspan style=\"color:red;\"\u003E3.58%\u003C\u002Fspan\u003E |\n| Revenue per subscriber | $6.39 | $6.40 | \u003Cspan style=\"color:red;\"\u003E-0.16%\u003C\u002Fspan\u003E |\n| MAU | 16,846 | 18,612 | \u003Cspan style=\"color:red;\"\u003E-9.49%\u003C\u002Fspan\u003E |\n| MAU → Subscriber conversion rate | 18% | 16.8% | \u003Cspan style=\"color:green;\"\u003E7.14%\u003C\u002Fspan\u003E |\n| Artist Alley listing weeks sold | 73 | 89 | \u003Cspan style=\"color:red;\"\u003E-17.98%\u003C\u002Fspan\u003E |\n\nNot great!","postingProject":{"projectId":3,"handle":"staff","displayName":"cohost dot org","dek":"the website you're on right now","description":"brought to you by @vogon @jkap @aidan @kaara\r\n\r\n@anti-software-software-club \r\n\r\n@staff is on the clock from **9am EST to 5pm PST** every weekday.\r\n****\r\n\r\nBe sure to check out the status of known bugs, feature requests, and other site improvements in the notion link above. \r\n***\r\n\r\n\r\nfind our FAQ and support documents at https:\u002F\u002Fantisoftware.freshdesk.com\u002Fsupport\u002Fsolutions\r\n***\r\nTo contact us directly, email support@cohost.org\r\n***\r\nthank you for using cohost!","avatarURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F3-3e0584c7-957a-4950-81ba-fb5a25d05e59-profile.png","avatarPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F3-3e0584c7-957a-4950-81ba-fb5a25d05e59-profile.png","headerURL":null,"headerPreviewURL":null,"privacy":"public","url":"https:\u002F\u002Fassc.notion.site\u002F","pronouns":"","flags":["staff","friendOfTheSite"],"avatarShape":"egg","loggedOutPostVisibility":"public","frequentlyUsedTags":["cohost corner","financials"],"askSettings":{"enabled":false,"allowAnon":false,"requireLoggedInAnon":true},"contactCard":[{"service":"helpdesk","value":"https:\u002F\u002Fhelp.antisoftware.club","visibility":"public"},{"service":"corporate website","value":"https:\u002F\u002Fantisoftware.club\u002F","visibility":"public"},{"service":"merch","value":"https:\u002F\u002Fstore.antisoftware.club","visibility":"public"}],"deleteAfter":null,"isSelfProject":null},"shareTree":[],"numSharedComments":0,"relatedProjects":[],"singlePostPageUrl":"https:\u002F\u002Fcohost.org\u002Fstaff\u002Fpost\u002F7611443-cohost-to-shut-down","effectiveAdultContent":false,"isEditor":false,"hasAnyContributorMuted":false,"contributorBlockIncomingOrOutgoing":false,"postEditUrl":"https:\u002F\u002Fcohost.org\u002Fstaff\u002Fpost\u002F7611443-cohost-to-shut-down\u002Fedit","isLiked":false,"canShare":true,"canPublish":true,"limitedVisibilityReason":"none","astMap":{"spans":[{"startIndex":0,"endIndex":8,"ast":"{\"type\":\"root\",\"children\":[{\"type\":\"element\",\"tagName\":\"p\",\"properties\":{},\"children\":[{\"type\":\"element\",\"tagName\":\"em\",\"properties\":{},\"children\":[{\"type\":\"text\",\"value\":\"also the August 2024 financial update, but I’m trying not to bury the lede.\",\"position\":{\"start\":{\"line\":1,\"column\":2,\"offset\":1},\"end\":{\"line\":1,\"column\":77,\"offset\":76}}}],\"position\":{\"start\":{\"line\":1,\"column\":1,\"offset\":0},\"end\":{\"line\":1,\"column\":