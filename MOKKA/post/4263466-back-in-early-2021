arPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F58038-8127b2ea-331a-4b02-a2ba-70928198b5e8-profile.jpeg","headerURL":null,"headerPreviewURL":null,"privacy":"public","url":"","pronouns":"","flags":[],"avatarShape":"circle","loggedOutPostVisibility":"public","frequentlyUsedTags":[],"askSettings":{"enabled":true,"allowAnon":true,"requireLoggedInAnon":true},"contactCard":[],"deleteAfter":null,"isSelfProject":null}],"singlePostPageUrl":"https:\u002F\u002Fcohost.org\u002FMOKKA\u002Fpost\u002F4263466-back-in-early-2021","effectiveAdultContent":false,"isEditor":false,"hasAnyContributorMuted":false,"contributorBlockIncomingOrOutgoing":false,"postEditUrl":"https:\u002F\u002Fcohost.org\u002FMOKKA\u002Fpost\u002F4263466-back-in-early-2021\u002Fedit","isLiked":true,"canShare":true,"canPublish":true,"limitedVisibilityReason":"none","astMap":{"spans":[{"startIndex":0,"endIndex":4,"ast":"{\"type\":\"root\",\"children\":[{\"type\":\"element\",\"tagName\":\"p\",\"properties\":{},\"children\":[{\"type\":\"element\",\"tagName\":\"a\",\"properties\":{\"href\":\"https:\u002F\u002Fmokkograd.net\u002Fposts\u002F2021-02-18-Individualsit%20production%20under%20capitalism\"},\"children\":[{\"type\":\"text\",\"value\":\"I wrote this blogpost\",\"position\":{\"start\":{\"line\":1,\"column\":2,\"offset\":1},\"end\":{\"line\":1,\"column\":23,\"offset\":22}}}],\"position\":{\"start\":{\"line\":1,\"column\":1,\"offset\":0},\"end\":{\"line\":1,\"column\":112,\"offset\":111}}},{\"type\":\"text\",\"value\":\" about how his descriptions of the early shift from individualised production of goods (=one person works to create something) to socialised production (=a lot of people work together to create something) under Capitalism reminded me how it feels to make games on your own, while having to sell them right next to AAA titles:\",\"position\":{\"start\":{\"line\":1,\"column\":112,\"offset\":111},\"end\":{\"line\":1,\"column\":437,\"offset\":436}}}],\"position\":{\"start\":{\"line\":1,\"column\":1,\"offset\":0},\"end\":{\"line\":1,\"column\":437,\"offset\":436}}},{\"type\":\"text\",\"value\":\"\\n\"},{\"type\":\"element\",\"tagName\":\"p\",\"properties\":{},\"children\":[{\"type\":\"text\",\"value\":\"I'm not sharing this to do a \\\"go and read some theory, friends\\\", but more because I'm really tired of seeing people try to fight this stuff on their own, when the only real way through this, is when we pool our resources and knowledge together.\",\"position\":{\"start\":{\"line\":3,\"column\":1,\"offset\":438},\"end\":{\"line\":3,\"column\":245,\"offset\":682}}}],\"position\":{\"start\":{\"line\":3,\"column\":1,\"offset\":438},\"end\":{\"line\":3,\"column\":245,\"offset\":682}}},{\"type\":\"text\",\"value\":\"\\n\"},{\"type\":\"element\",\"tagName\":\"p\",\"properties\":{},\"children\":[{\"type\":\"text\",\"value\":\"I want for all of us to be in a better position to make the things that we want to make, and most of the things that would be needed for that are not possible without major political shifts across the entire world. However, I do believe that we all can do more to help each other, to pool our resources, to share knowledge. I'm very much to blame here as well, not because I don't trust people, but because talking to them makes me scared and I also have this fundamental belief that I don't have anything of value to offer to anyone. But I would like to help, as I would like for all of us to help each other.\",\"position\":{\"start\":{\"line\":5,\"column\":1,\"offset\":684},\"end\":{\"line\":5,\"column\":611,\"offset\":1294}}}],\"position\":{\"start\":{\"line\":5,\"column\":1,\"offset\":684},\"end\":{\"line\":5,\"column\":611,\"offset\":1294}}},{\"type\":\"text\",\"value\":\"\\n\"},{\"type\":\"element\",\"tagName\":\"p\",\"properties\":{},\"children\":[{\"type\":\"text\",\"value\":\"(Apologies if this reads incoherent, it's almost 1am over here and I was supposed to go to bed when I saw these posts)\",\"position\":{\"start\":{\"line\":7,\"column\":1,\"offset\":1296},\"end\":{\"line\":7,\"column\":119,\"offset\":1414}}}],\"position\":{\"start\":{\"line\":7,\"column\":1,\"offset\":1296},\"end\":{\"line\":7,\"column\":119,\"offset\":1414}}}],\"data\":{\"quirksMode\":false},\"position\":{\"start\":{\"line\":1,\"column\":1,\"offset\":0},\"end\":{\"line\":7,\"column\":119,\"offset\":1414}}}"}],"readMoreIndex":null},"responseToAskId":null},"comments":{"4256715":[{"comment":{"commentId":"fb2a9a10-528b-48e7-8d98-94dfc8fde506","postedAtISO":"2024-01-23T05:34:59.843Z","deleted":false,"body":"Listen, this is a good post, and what you've said is all true. And what I want to draw your attention is not the massive slop games that are always going to be fine, but that we have an indie scene at all! Indies have always had an uphill battle, but twenty years ago it was almost impossible to make money with them _period_. They would get _zero_ coverage from the press, and you couldn't sell them in big box stores. A lot of the games industry is still horseshit, but we are always continuously twirling toward greatness. Finally, if it's all just getting to you, I encourage you to seek out the players. I promise you that more people love games, even the small ones, than hate them.","children":[],"postId":4256715,"inReplyTo":null,"hasCohostPlus":true,"hidden":false},"canInteract":"allowed","canEdit":"not-allowed","canHide":"not-allowed","poster":{"projectId":11237,"handle":"mrhands","displayName":"Mr. Hands","dek":"Sexy game(s) maker","description":"I do UI programming for AAA games and I have _opinions_ about adult games","avatarURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F11237-6d95b58a-06cd-4107-9149-ebcc05475df2-profile.jpg","avatarPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F11237-6d95b58a-06cd-4107-9149-ebcc05475df2-profile.jpg","headerURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Fheader\u002F11237-d81c43bc-75ed-472d-8b2f-42d186b2ca8c-profile.jpg","headerPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Fheader\u002F11237-d81c43bc-75ed-472d-8b2f-42d186b2ca8c-profile.jpg","privacy":"public","url":"","pronouns":"he\u002Fhim","flags":[],"avatarShape":"roundrect","loggedOutPostVisibility":"public","frequentlyUsedTags":["uptheretheylove","NaughtyListNews","gamedev","home improvement"],"askSettings":{"enabled":true,"allowAnon":true,"requireLoggedInAnon":true},"contactCard":[{"service":"Discord","value":"mrhands31","visibility":"public"}],"deleteAfter":null,"isSelfProject":null}},{"comment":{"commentId":"40283c47-704e-4ae7-b2a9-13442fa81279","postedAtISO":"2024-01-23T11:56:25.532Z","deleted":false,"body":"i am right there with you, but... i think the problem is not journalists or players being blind and\u002For dumb, i think the problem is that *the game* in which we are making games is rigged.\n\n\nevery human on this planet is currently trying to make the most money they possibly can, and sadly that also means shoving the little ones out of the way so the big ones can fully unfold their blank money-collecting-canvases.\n\n\ni would love to make a living with something i love, but there are already people out there grabbing the cash... so i hope real indie games will never fully die, but i doubt there will be much profit in the coming decades in this venue.\n\nit's the tragedy of the commons all over again.\n - a space is created\n - a space is used cooperatively according to *the rules* that everyone already knows\n - people who havent heard of *the rules* come in and just do it *their way*\n - people get mad about other people in the commons and \"say they are not true commoners\" or \"they are doing it wrong\"\n - people erect fences to claim that nook of the space as \"theirs\" (so you want to make a cartoon with a mouse that is wearing gloves? curious....)\n\n\ni think the only way is to just move the whole space.\nthis year its \"indie games\" next its gremlingames or hobgobgames or shitgames.\n\nand the moment an AAAAAAAAsshole sees it and wants it, we can just say: \"actually this is crap.\" BAM! CRAPGAMES!","children":[{"comment":{"commentId":"7434296b-2914-4a13-9fc8-388dcba0ba86","postedAtISO":"2024-01-23T12:26:45.164Z","deleted":false,"body":"yeah, i wanna be clear that i don't think what i'm complaining about is the cause of the problem, it's a symptom. the thing i'm trying to get at is how isolating it feels that people who act like they want to help won't listen and don't get it. that the whole medium is having the goddamn life squeezed out of it and people act like it's normal!","children":[{"comment":{"commentId":"c40134ff-aa1d-49f6-bd82-7e626255dd40","postedAtISO":"2024-01-23T13:59:35.555Z","deleted":false,"body":"well, i dont think this is the right medium for any in-depth discussion... so, i guess if you disagree with what i said, i'll just have to concede: i dont get your point","children":[],"postId":4256715,"inReplyTo":"7434296b-2914-4a13-9fc8-388dcba0ba86","hasCohostPlus":false,"hidden":false},"canInteract":"allowed","canEdit":"not-allowed","canHide":"not-allowed","poster":{"projectId":8413,"handle":"Janet","displayName":"","dek":"","description":"22\u002F9\u002F22","avatarURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F8413-f412f177-bacd-4ddb-98a7-0b25a552a158-profile.png","avatarPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F8413-f412f177-bacd-4ddb-98a7-0b25a552a158-profile.png","headerURL":null,"headerPreviewURL":null,"privacy":"public","url":"","pronouns":"","flags":[],"avatarShape":"roundrect","loggedOutPostVisibility":"public","frequentlyUsedTags":[],"askSettings":{"enabled":true,"allowAnon":true,"requireLoggedInAnon":true},"contactCard":[],"deleteAfter":null,"isSelfProject":null}}],"postId":4256715,"inReplyTo":"40283c47-704e-4ae7-b2a9-13442fa81279","hasCohostPlus":false,"hidden":false},"canInteract":"allowed","canEdit":"not-allowed","canHide":"not-allowed","poster":{"projectId":503,"handle":"prophetgoddess","display