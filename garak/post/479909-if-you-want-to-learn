ailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["projects","isReaderMuting"],{"input":{"projectHandle":"garak"},"type":"query"}],"queryHash":"[[\"projects\",\"isReaderMuting\"],{\"input\":{\"projectHandle\":\"garak\"},\"type\":\"query\"}]"},{"state":{"data":false,"dataUpdateCount":1,"dataUpdatedAt":1727235574219,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["projects","isReaderBlocking"],{"input":{"projectHandle":"garak"},"type":"query"}],"queryHash":"[[\"projects\",\"isReaderBlocking\"],{\"input\":{\"projectHandle\":\"garak\"},\"type\":\"query\"}]"},{"state":{"data":{"readerToProject":2},"dataUpdateCount":1,"dataUpdatedAt":1727235574231,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["projects","followingState"],{"input":{"projectHandle":"garak"},"type":"query"}],"queryHash":"[[\"projects\",\"followingState\"],{\"input\":{\"projectHandle\":\"garak\"},\"type\":\"query\"}]"},{"state":{"data":{"post":{"postId":479909,"headline":"","publishedAt":"2022-11-28T15:43:34.156Z","filename":"479909-if-you-want-to-learn","transparentShareOfPostId":null,"shareOfPostId":479771,"state":1,"numComments":8,"cws":[],"tags":[],"hasCohostPlus":true,"pinned":false,"commentsLocked":false,"sharesLocked":false,"blocks":[{"type":"markdown","markdown":{"content":"If you want to learn control flow that will thoroughly shake the foundations of how you think computers ought to work, then I recommend pointing your face in the direction of Prolog. It's not so much a control flow operator (although \"cut\" `!` is certainly something), but rather how evaluation works in the whole language."}},{"type":"markdown","markdown":{"content":"In an imperative language, the three main operations are variable assignments, function calls, and sequencing. In Prolog, the two main operators are unification and backtracking. The equivalent of a function call establishes provisional values to variables. And then if that creates a problem, then the function unwinds the work it's done and starts over with new values. I want to reinforce, this is not just a trick which can be used sometimes, this is the **primary control flow** for the language."}},{"type":"markdown","markdown":{"content":"As an example, let's saying you write in Prolog the rules for checking a Sudoku solution. Your source code contains the rules, one by one, of what makes a solution correct. That's all you do."}},{"type":"markdown","markdown":{"content":"That program is a Sudoku *solver*. The solving happens just by calling the function you defined with some values unassigned, and the semantics of Prolog are to fill it in with a valid solution. (The strategy it uses for doing so depends on *how* you specify the rules.)"}},{"type":"markdown","markdown":{"content":"One of my favorite things about Prolog is that normal languages you need to define separate \"print\" and \"parse\" methods but in Prolog you can sometimes get away with just one function that can do either. You define a correspondence between data and a string. You can print by calling that function with data but no string, and it fills in the string; and you can parse by calling it with a string but not data, and it fills in the data. "}},{"type":"markdown","markdown":{"content":"In practice, Prolog tends to be used in very small amounts in large systems. There are some tasks where a few dozen lines of Prolog can replace *thousands* of lines of imperative code; and that's the only situation where the complexity is worthwhile. To my understanding, the Windows kernel uses Prolog for its network filtering rules, which is in the same ballpark as a Sudoku solver."}}],"plainTextBody":"If you want to learn control flow that will thoroughly shake the foundations of how you think computers ought to work, then I recommend pointing your face in the direction of Prolog. It's not so much a control flow operator (although \"cut\" `!` is certainly something), but rather how evaluation works in the whole language.\n\nIn an imperative language, the three main operations are variable assignments, function calls, and sequencing. In Prolog, the two main operators are unification and backtracking. The equivalent of a function call establishes provisional values to variables. And then if that creates a problem, then the function unwinds the work it's done and starts over with new values. I want to reinforce, this is not just a trick which can be used sometimes, this is the **primary control flow** for the language.\n\nAs an example, let's saying you write in Prolog the rules for checking a Sudoku solution. Your source code contains the rules, one by one, of what makes a solution correct. That's all you do.\n\nThat program is a Sudoku *solver*. The solving happens just by calling the function you defined with some values unassigned, and the semantics of Prolog are to fill it in with a valid solution. (The strategy it uses for doing so depends on *how* you specify the rules.)\n\nOne of my favorite things about Prolog is that normal languages you need to define separate \"print\" and \"parse\" methods but in Prolog you can sometimes get away with just one function that can do either. You define a correspondence between data and a string. You can print by calling that function with data but no string, and it fills in the string; and you can parse by calling it with a string but not data, and it fills in the data. \n\nIn practice, Prolog tends to be used in very small amounts in large systems. There are some tasks where a few dozen lines of Prolog can replace *thousands* of lines of imperative code; and that's the only situation where the complexity is worthwhile. To my understanding, the Windows kernel uses Prolog for its network filtering rules, which is in the same ballpark as a Sudoku solver.","postingProject":{"projectId":16192,"handle":"garak","displayName":"","dek":"Lorem Ipsem","description":"A sequence of bit-flips on Cohost's servers, such as those caused by cosmic radiation. There's no evidence of anything more.\r\n----\r\nAlso responsible for @carpediem, find out the secret reason why each day is special.","avatarURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F16192-635b79a8-3faa-410b-86d4-15606e06a3bb-profile.png","avatarPreviewURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Favatar\u002F16192-635b79a8-3faa-410b-86d4-15606e06a3bb-profile.png","headerURL":"https:\u002F\u002Fstaging.cohostcdn.org\u002Fheader\u002F16192-74185f7a-ce44-409b-acd7-6c019206d729-profile.gif","headerPreviewURL":"https:\u002F\u002Fproxy-staging.cohostcdn.org\u002FFKS8JB8mf02njfPMzpvh4n-wSr78gJvkYWg9Rua7FtA\u002Ff:png\u002FczM6Ly9jb2hvc3QtcHJvZC9oZWFkZXIvMTYxOTItNzQxODVmN2EtY2U0NC00MDliLWFjZDctNmMwMTkyMDZkNzI5LXByb2ZpbGUuZ2lm","privacy":"public","url":"","pronouns":"hic\u002Fhaec\u002Fhoc","flags":[],"avatarShape":"squircle","loggedOutPostVisibility":"public","frequentlyUsedTags":["mathposting","css crimes","cursed math","book of days"],"askSettings":{"enabled":true,"allowAnon":true,"requireLoggedInAnon":true},"contactCard":[],"deleteAfter":null,"isSelfProject":null},"shareTree":[{"postId":478271,"headline":"What's Your Favorite Code Flow Control?","publishedAt":"2022-11-28T08:02:47.376Z","filename":"478271-what-s-your-favorite","transparentShareOfPostId":null,"shareOfPostId":null,"state":1,"numComments":35,"cws":[],"tags":["programming","programming languages","programming language development","coding","flow control"],"hasCohostPlus":true,"pinned":false,"commentsLocked":false,"sharesLocked":false,"blocks":[{"type":"markdown","markdown":{"content":"The question here is \"what's your favorite non-C-like flow control statement\u002Fconstruct that you've seen in a programming language\" but I'm gonna start with a little preamble."}},{"type":"markdown","markdown":{"content":"---\nI'm very familiar with C-style flow control:"}},{"type":"markdown","markdown":{"content":"\u003Cpre style=\"background-color:rgb(25, 23, 28);color:rgb(139, 135, 146);position:relative;padding:0;line-height:1.2rem;margin-bottom:0\"\u003E\u003Ccode style=\"padding:0 16px;display:block;margin-bottom:9px;margin-top:9px\"\u003E\u003Cspan style=\"\"\u003E\u003Cspan style=\"color: rgb(149, 90, 231)\"\u003Eif\u003C\u002Fspan\u003E (condition)\n  { thing; }\n\u003Cspan style=\"color: rgb(149, 90, 231)\"\u003Eelse\u003C\u002Fspan\u003E \n  { otherThing; }"}},{"type":"markdown","markdown":{"content":"\n\u003Cspan style=\"color: rgb(126, 120, 135)\"\u003E\u002F\u002F And, thanks to C++17:\u003C\u002Fspan\u003E\n\u003Cspan style=\"color: rgb(149, 90, 231)\"\u003Eif\u003C\u002Fspan\u003E (auto v= initializer(); condition) \n  { thing(v); }\n\u003Cspan style=\"color: rgb(149, 90, 231)\"\u003Eelse\u003C\u002Fspan\u003E \n  { otherThing(v); }\u003C\u002Fspan\u003E\u003C\u002Fspan\u003E\u003C\u002Fcode\u003E\u003C\u002Fpre\u003E\u003Cdiv style=\"text-align: right; font-size: min(1.87vw, 70%); opacity: 0.7; margin-bottom: 1.7142857em;\"\u003Emade with @nex3's \u003Ca href=\"https:\u002F\u002Fnex3.github.io\u002Fcohost-highlight\"\u003Esyntax highlighter\u003C\u002Fa\u003E\u003C\u002Fdiv\u003E"}},{"type":"markdown","markdown":{"content":"\u003Cpre style=\"background-color:rgb(25, 23, 28);color:rgb(139, 135, 146);position:relative;padding:0;line-height:1.2rem;margin-bottom:0\"\u003E\u003Ccode style=\"padding:0 16px;display:block;margin-bottom:9px;margin-top:9px\"\u003E\u003Cspan style=\"\"\u003E\u003Cspan style=\"color: rgb(149, 90, 231)\"\u003Efor\u003C\u002Fspan\u003E (\u003Cspan style=\"color: rgb(149, 90, 231)\"\u003Eint\u003C\u002Fspan\u003E i = \u003Cspan style=\"color: rgb(170, 87, 60)\"\u003E0\u003C\u002Fspan\u003E; i &lt; \u0